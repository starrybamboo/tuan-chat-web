{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "unicorn",
    "react",
    "vitest",
    "node",
    "import",
    "jsx-a11y"
  ],
  "ignorePatterns": [
    "public/**",
    "api/**",
    "packages/tuanchat-openapi-client/**",
    ".github/**",
    "**/*.md",
    "android/**",
    ".pnpm-patch-work/**",
    "patches/**",
    "apps/mobile/.tmp/**",
    "build/**",
    "dist/**",
    "release/**",
    "coverage/**",
    "node_modules/.cache/**"
  ]
}
