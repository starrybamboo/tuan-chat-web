{
  "$schema": "../../node_modules/oxlint/configuration_schema.json",
  "jsPlugins": [
    {
      "name": "react-hooks-js",
      "specifier": "eslint-plugin-react-hooks"
    },
    {
      "name": "perfectionist",
      "specifier": "eslint-plugin-perfectionist"
    }
  ],
  "plugins": [
    "typescript",
    "unicorn",
    "react",
    "node"
  ],
  "rules": {},
  "overrides": [
    {
      "files": [
        "**/*.{js,jsx,ts,tsx}"
      ],
      "rules": {
        "typescript/no-redeclare": "off",
        "typescript/consistent-type-definitions": [
          "warn",
          "type"
        ],
        "typescript/no-use-before-define": "off",
        "typescript/no-require-imports": "off",
        "no-console": [
          "warn",
          {
            "allow": [
              "warn",
              "error"
            ]
          }
        ],
        "node/no-process-env": "off",
        "perfectionist/sort-imports": [
          "warn",
          {
            "tsconfigRootDir": "."
          }
        ],
        "unicorn/filename-case": [
          "error",
          {
            "cases": {
              "camelCase": true,
              "kebabCase": true,
              "pascalCase": true
            }
          }
        ],
        "react-hooks-js/immutability": "warn",
        "react-hooks-js/preserve-manual-memoization": "warn",
        "react-hooks-js/purity": "warn",
        "react-hooks-js/refs": "warn",
        "react-hooks-js/set-state-in-effect": "warn",
        "react-hooks-js/static-components": "warn",
        "react/no-array-index-key": "off"
      }
    }
  ],
  "ignorePatterns": [
    ".expo/**",
    ".expo-export-web/**",
    ".tmp/**",
    "android/**",
    "ios/**",
    "node_modules/**",
    "scripts/**"
  ]
}
