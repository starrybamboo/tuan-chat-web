{
  "name": "@tuanchat/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --port 8082",
    "start:local-backend": "powershell -ExecutionPolicy Bypass -File ./scripts/start-local-backend.ps1",
    "dev": "expo start --port 8082",
    "build:web": "expo export --platform web --output-dir .expo-export-web",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web --port 8082",
    "lint": "node ../../scripts/run-oxlint.mjs . --config ./.oxlintrc.jsonc --no-error-on-unmatched-pattern",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@expo/dom-webview": "~57.0.1",
    "@expo/metro-runtime": "~57.0.6",
    "@nandorojo/galeria": "3.0.3",
    "@react-native-menu/menu": "2.0.0",
    "@react-navigation/native": "^7.1.33",
    "@shopify/flash-list": "2.3.2",
    "@tanstack/react-query": "^5.101.2",
    "@tuanchat/domain": "workspace:*",
    "@tuanchat/local-db": "workspace:*",
    "@tuanchat/openapi-client": "workspace:*",
    "@tuanchat/query": "workspace:*",
    "expo": "~57.0.7",
    "expo-asset": "~57.0.6",
    "expo-audio": "~57.0.2",
    "expo-build-properties": "57.0.6",
    "expo-clipboard": "~57.0.1",
    "expo-document-picker": "~57.0.1",
    "expo-file-system": "~57.0.1",
    "expo-image": "~57.0.1",
    "expo-image-manipulator": "~57.0.5",
    "expo-image-picker": "~57.0.5",
    "expo-linking": "~57.0.3",
    "expo-notifications": "~57.0.6",
    "expo-router": "~57.0.7",
    "expo-secure-store": "^57.0.1",
    "expo-sharing": "~57.0.6",
    "expo-splash-screen": "~57.0.4",
    "expo-sqlite": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "expo-video": "~57.0.1",
    "gifuct-js": "2.1.2",
    "phosphor-react-native": "^3.0.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-ios-context-menu": "3.1.0",
    "react-native-ios-utilities": "5.1.2",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "^15.15.4",
    "react-native-web": "~0.21.2",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.10.0",
    "wasm-webp": "0.1.0",
    "zeego": "3.0.6"
  },
  "devDependencies": {
    "@tuanchat/oxlint-config": "workspace:*",
    "@tuanchat/typescript-config": "workspace:*",
    "@types/react": "~19.2.17",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "typescript": "6.0.3"
  },
  "expo": {
    "install": {
      "exclude": [
        "@shopify/flash-list"
      ]
    }
  }
}
