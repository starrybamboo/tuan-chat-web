{
  "extends": "./tsconfig.expo-base.json",
  "compilerOptions": {
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/assets/*": [
        "./assets/*"
      ],
      "@tuanchat/domain": [
        "../../packages/tuanchat-domain/src/index.ts"
      ],
      "@tuanchat/domain/*": [
        "../../packages/tuanchat-domain/src/*"
      ],
      "@tuanchat/local-db": [
        "../../packages/tuanchat-local-db/src/index.ts"
      ],
      "@tuanchat/local-db/*": [
        "../../packages/tuanchat-local-db/src/*"
      ],
      "@tuanchat/openapi-client": [
        "../../packages/tuanchat-openapi-client/src/index.ts"
      ],
      "@tuanchat/openapi-client/*": [
        "../../packages/tuanchat-openapi-client/src/*"
      ],
      "@tuanchat/query": [
        "../../packages/tuanchat-query/src/index.ts"
      ],
      "@tuanchat/query/*": [
        "../../packages/tuanchat-query/src/*"
      ]
    },
    "strict": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
