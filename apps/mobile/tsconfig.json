{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/assets/*": [
        "./assets/*"
      ],
      "@tuanchat/openapi-client": [
        "../../packages/tuanchat-openapi-client/src/index.ts"
      ],
      "@tuanchat/openapi-client/*": [
        "../../packages/tuanchat-openapi-client/src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
