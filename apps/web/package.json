{
  "name": "@tuanchat/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "dev": "node ./scripts/dev.mjs",
    "dev:force": "node ./scripts/dev.mjs --force",
    "start": "node ./scripts/start.mjs",
    "lint": "oxlint . --config ./.oxlintrc.json --no-error-on-unmatched-pattern",
    "lint:fix": "oxlint . --config ./.oxlintrc.json --fix --fix-suggestions --no-error-on-unmatched-pattern",
    "typecheck": "tsgo -p tsconfig.typecheck.json",
    "typecheck:tsc": "tsc -p tsconfig.typecheck.json",
    "typecheck:tsgo": "tsgo -p tsconfig.typecheck.json",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "optimize:ai-style-images": "node ../../scripts/optimize-ai-style-images.mjs"
  },
  "dependencies": {
    "@ffmpeg/core": "0.12.9",
