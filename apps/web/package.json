  "devDependencies": {
    "@babel/core": "7.29.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/eslint-plugin-query": "^5.68.0",
    "@tanstack/router-plugin": "1.168.6",
