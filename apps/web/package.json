    "@tuanchat/openapi-client": "workspace:*",
    "@tuanchat/query": "workspace:*",
    "@uidotdev/usehooks": "^2.4.1",
    "@xyflow/react": "^12.8.2",
    "ahooks": "^3.8.5",
    "browser-image-compression": "^2.0.2",
    "dagre": "^0.8.5",
    "fflate": "0.8.2",
    "html-to-image": "^1.11.13",
    "immer": "10.1.1",
    "motion": "^12.38.0",
    "pinyin-pro": "^3.28.1",
    "pixi.js": "^8.6.6",
    "qrcode": "^1.5.4",
    "react": "19.2.0",
    "react-advanced-cropper": "0.20.1",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.55.0",
