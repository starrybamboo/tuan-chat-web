{
  "name": "@tuanchat/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "dev": "node ./scripts/dev.mjs",
    "dev:force": "node ./scripts/dev.mjs --force",
    "start": "node ./scripts/start.mjs",
    "lint": "node ../../scripts/run-oxlint.mjs . --config ./.oxlintrc.jsonc --no-error-on-unmatched-pattern",
    "lint:fix": "node ../../scripts/run-oxlint.mjs . --config ./.oxlintrc.jsonc --fix --no-error-on-unmatched-pattern",
    "lint:fix:suggestions": "node ../../scripts/run-oxlint.mjs . --config ./.oxlintrc.jsonc --fix --fix-suggestions --no-error-on-unmatched-pattern",
    "typecheck": "tsgo -p tsconfig.typecheck.json",
    "typecheck:tsc": "tsc -p tsconfig.typecheck.json",
    "typecheck:tsgo": "tsgo -p tsconfig.typecheck.json",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "optimize:ai-style-images": "node ../../scripts/optimize-ai-style-images.mjs"
  },
  "dependencies": {
    "@ffmpeg/core": "0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@huggingface/tokenizers": "^0.1.3",
    "@phosphor-icons/react": "^2.1.10",
    "@sqlite.org/sqlite-wasm": "3.53.0-build1",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "1.170.18",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tuanchat/domain": "workspace:*",
    "@tuanchat/local-db": "workspace:*",
    "@tuanchat/openapi-client": "workspace:*",
    "@tuanchat/query": "workspace:*",
    "@uidotdev/usehooks": "^2.4.1",
    "@xyflow/react": "^12.11.2",
    "ahooks": "^3.9.7",
    "browser-image-compression": "^2.0.2",
    "dagre": "^0.8.5",
    "fflate": "0.8.3",
    "html-to-image": "^1.11.13",
    "immer": "11.1.15",
    "motion": "^12.42.2",
    "pinyin-pro": "^3.28.1",
    "pixi.js": "^8.19.0",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-advanced-cropper": "0.20.1",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.81.0",
    "react-hot-toast": "^2.6.0",
    "react-image-crop": "^11.1.2",
    "react-markdown": "^10.1.0",
    "react-scan": "0.5.7",
    "react-virtuoso": "^4.18.11",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "ts-md5": "^2.0.1",
    "undici": "^8.7.0",
    "use-immer": "^0.11.0",
    "vaul": "^1.1.2",
    "wavesurfer.js": "^7.12.11",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.3",
    "@tanstack/eslint-plugin-query": "^5.101.2",
    "@tanstack/router-plugin": "1.168.20",
    "@tuanchat/electron-ipc": "workspace:*",
    "@tuanchat/typescript-config": "workspace:*",
    "@types/node": "^22.19.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "babel-plugin-react-compiler": "1.0.0",
    "daisyui": "^5.6.18",
    "esbuild": "^0.28.1",
    "eslint-plugin-better-tailwindcss": "^4.6.1",
    "eslint-plugin-react-dom": "^5.17.1",
    "oxlint": "1.74.0",
    "tailwindcss": "^4.3.3",
    "typescript": "6.0.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
