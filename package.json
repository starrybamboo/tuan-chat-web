{
  "name": "tuan-chat-web",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "author": "Tuan Chat",
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "build:web": "pnpm web:build",
    "build:workspace": "pnpm build:web && pnpm --filter @tuanchat/mobile run build:web",
    "web:build": "pnpm --filter @tuanchat/web run build",
    "dev": "node ./scripts/dev.mjs",
    "web:dev": "pnpm --filter @tuanchat/web run dev",
    "dev:force": "node ./scripts/dev.mjs --force",
    "start": "node ./scripts/start.mjs",
    "web:start": "pnpm --filter @tuanchat/web run start",
    "mobile:local-apk": "powershell -ExecutionPolicy Bypass -Command \"$env:NODE_ENV='production'; & './scripts/mobile-android-apk.ps1' -Variant Release -Architectures arm64-v8a -ApiBaseUrl 'https://api.tuan.chat/api' -WebSocketUrl 'wss://api.tuan.chat/ws'\"",
    "mobile:debug-apk": "powershell -ExecutionPolicy Bypass -File ./scripts/mobile-android-debug-apk.ps1",
    "mobile:cloud-apk": "cd apps/mobile && pnpm dlx eas-cli@21.0.2 build -p android --profile preview",
    "mobile:workflow:preview": "cd apps/mobile && pnpm dlx eas-cli@21.0.2 workflow:run .eas/workflows/build-main-preview-builds.yml",
    "mobile:workflow:production": "cd apps/mobile && pnpm dlx eas-cli@21.0.2 workflow:run .eas/workflows/create-production-builds.yml --non-interactive --json",
    "mobile:ios:credentials": "cd apps/mobile && pnpm dlx eas-cli@21.0.2 credentials -p ios",
    "mobile:ios:bootstrap-production": "cd apps/mobile && pnpm dlx eas-cli@21.0.2 build -p ios --profile production",
    "mobile:start": "pnpm --filter @tuanchat/mobile start",
    "mobile:start:local-backend": "powershell -ExecutionPolicy Bypass -File ./apps/mobile/scripts/start-local-backend.ps1",
    "mobile:android": "cd apps/mobile && pnpm exec expo start --port 8082 --android",
    "mobile:ios": "pnpm --filter @tuanchat/mobile ios",
    "mobile:web": "pnpm --filter @tuanchat/mobile web",
    "mobile:typecheck": "pnpm --filter @tuanchat/mobile typecheck",
    "typecheck": "pnpm typecheck:web",
    "typecheck:all": "pnpm typecheck:web && pnpm typecheck:mobile",
    "typecheck:mobile": "pnpm --filter @tuanchat/mobile typecheck",
    "typecheck:tsc": "pnpm --filter @tuanchat/web run typecheck:tsc",
    "typecheck:tsgo": "pnpm --filter @tuanchat/web run typecheck:tsgo",
    "typecheck:web": "pnpm --filter @tuanchat/web run typecheck",
    "typecheck:repo": "tsgo -p tsconfig.typecheck.json",
    "typecheck:repo:tsc": "tsc -p tsconfig.typecheck.json",
    "lint": "pnpm lint:repo && pnpm lint:web && pnpm lint:desktop",
    "lint:all": "pnpm lint:repo && pnpm lint:web && pnpm lint:desktop && pnpm lint:mobile",
    "lint:fix": "pnpm lint:web:fix",
    "lint:fix:suggestions": "pnpm lint:web:fix:suggestions",
    "lint:desktop": "pnpm --filter @tuanchat/desktop run lint",
    "lint:mobile": "pnpm --filter @tuanchat/mobile lint",
    "lint:repo": "node ./scripts/run-oxlint.mjs . --config .oxlintrc.jsonc --no-error-on-unmatched-pattern",
    "lint:ox": "pnpm lint:repo",
    "lint:ox:fix": "node ./scripts/run-oxlint.mjs . --config .oxlintrc.jsonc --fix --no-error-on-unmatched-pattern",
    "lint:ox:fix:suggestions": "node ./scripts/run-oxlint.mjs . --config .oxlintrc.jsonc --fix --fix-suggestions --no-error-on-unmatched-pattern",
    "lint:web": "pnpm --filter @tuanchat/web run lint",
    "lint:web:fix": "pnpm --filter @tuanchat/web run lint:fix",
    "lint:web:fix:suggestions": "pnpm --filter @tuanchat/web run lint:fix:suggestions",
    "knip": "knip --no-progress",
    "encoding:check": "node ./scripts/check-encoding.mjs",
    "design:check": "node ./scripts/check-design-language.mjs",
    "design:migration:report": "node ./scripts/check-design-language-migration.mjs",
    "design:migration:check": "node ./scripts/check-design-language-migration.mjs --strict",
    "test": "pnpm --filter @tuanchat/web run test",
    "test:watch": "pnpm --filter @tuanchat/web run test:watch",
    "test:coverage": "pnpm --filter @tuanchat/web run test:coverage",
    "analytics:login-easter-egg": "node ./scripts/query-login-easter-egg-analytics.mjs",
    "cloudflare:analytics:configure": "node ./scripts/configure-cloudflare-product-analytics.mjs",
    "optimize:ai-style-images": "pnpm --filter @tuanchat/web run optimize:ai-style-images",
    "backfill:list-avatar": "node ./scripts/backfill-space-avatar-compression.mjs",
    "backfill:space-avatar": "node ./scripts/backfill-space-avatar-compression.mjs",
    "prepare": "husky",
    "openapi": "openapi --input ./packages/tuanchat-openapi-client/tuanchat_OpenAPI.json --output ./packages/tuanchat-openapi-client/src --client fetch --name TuanChat && node ./scripts/patch-openapi-api-result-guard.mjs",
    "openapi:sync": "node ./scripts/sync-openapi-from-backend.mjs",
    "desktop:dev": "pnpm --filter @tuanchat/desktop run dev",
    "desktop:dev:only": "pnpm --filter @tuanchat/desktop run dev:only",
    "desktop:prepare:webgal": "pnpm --filter @tuanchat/desktop run prepare:webgal",
    "desktop:check:webgal": "pnpm --filter @tuanchat/desktop run check:webgal",
    "desktop:build:app": "pnpm --filter @tuanchat/desktop run build:app",
    "desktop:build": "pnpm --filter @tuanchat/desktop run build",
    "desktop:build:win:zip": "pnpm --filter @tuanchat/desktop run build:win:zip",
    "desktop:build:win:nsis": "pnpm --filter @tuanchat/desktop run build:win:nsis",
    "desktop:build:mac:zip": "pnpm --filter @tuanchat/desktop run build:mac:zip",
    "desktop:build:mac:dmg": "pnpm --filter @tuanchat/desktop run build:mac:dmg",
    "release:electron": "node ./scripts/release-electron.mjs",
    "electron:dev": "pnpm desktop:dev",
    "electron:dev:only": "pnpm desktop:dev:only",
    "electron:prepare:webgal": "pnpm desktop:prepare:webgal",
    "electron:check:webgal": "pnpm desktop:check:webgal",
    "electron:build": "pnpm desktop:build",
    "electron:build:win:zip": "pnpm desktop:build:win:zip",
    "electron:build:win:nsis": "pnpm desktop:build:win:nsis",
    "electron:build:mac:zip": "pnpm desktop:build:mac:zip",
    "electron:build:mac:dmg": "pnpm desktop:build:mac:dmg"
  },
  "devDependencies": {
    "@tuanchat/domain": "workspace:*",
    "@tuanchat/openapi-client": "workspace:*",
    "@tuanchat/typescript-config": "workspace:*",
    "@types/node": "^22.19.3",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "eslint": "^10.7.0",
    "fast-glob": "^3.3.3",
    "husky": "^9.1.7",
    "knip": "6.27.0",
    "lint-staged": "^15.5.0",
    "openapi-typescript-codegen": "^0.31.0",
    "oxlint": "1.74.0",
    "sharp": "^0.35.3",
    "typescript": "6.0.3",
    "undici": "^8.7.0",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "apps/web/**/*.{js,jsx,ts,tsx,mjs,cjs}": "node ./scripts/run-oxlint.mjs --fix --config apps/web/.oxlintrc.jsonc --no-error-on-unmatched-pattern",
    "apps/mobile/**/*.{js,jsx,ts,tsx,mjs,cjs}": "node ./scripts/run-oxlint.mjs --fix --config apps/mobile/.oxlintrc.jsonc --no-error-on-unmatched-pattern",
    "apps/desktop/**/*.{js,jsx,ts,tsx,mjs,cjs}": "node ./scripts/run-oxlint.mjs --fix --config apps/desktop/.oxlintrc.jsonc --no-error-on-unmatched-pattern",
    "{scripts,packages}/**/*.{js,jsx,ts,tsx,mjs,cjs}": "node ./scripts/run-oxlint.mjs --fix --config .oxlintrc.jsonc --no-error-on-unmatched-pattern",
    "*.{js,jsx,ts,tsx,mjs,cjs}": "node ./scripts/run-oxlint.mjs --fix --config .oxlintrc.jsonc --no-error-on-unmatched-pattern",
    "*.{ts,tsx,js,jsx,mjs,cjs,json,md,css,html,yml,yaml,ps1,sql}": "node ./scripts/check-encoding.mjs"
  }
}
