{
  "name": "tuan-chat-web",
  "type": "module",
  "version": "1.0.4",
  "private": true,
  "packageManager": "pnpm@9.6.0",
  "author": "Tuan Chat",
  "main": "electron/main.js",
  "scripts": {
    "build": "vite build",
    "dev": "node ./scripts/dev.mjs",
    "dev:force": "node ./scripts/dev.mjs --force",
    "start": "node ./scripts/start.mjs",
    "mobile:android:dev": "powershell -ExecutionPolicy Bypass -File ./scripts/mobile-android-dev.ps1",
    "mobile:android:emulator": "powershell -ExecutionPolicy Bypass -File ./scripts/mobile-start-android-emulator.ps1",
    "mobile:android:start": "powershell -ExecutionPolicy Bypass -File ./scripts/mobile-start-expo.ps1 -Android",
    "mobile:start": "pnpm --filter @tuanchat/mobile start",
    "mobile:android": "pnpm mobile:android:dev",
    "mobile:ios": "pnpm --filter @tuanchat/mobile ios",
    "mobile:web": "pnpm --filter @tuanchat/mobile web",
    "mobile:typecheck": "pnpm --filter @tuanchat/mobile typecheck",
    "typecheck": "pnpm typecheck:tsgo",
    "typecheck:tsc": "tsc -p tsconfig.typecheck.json",
    "typecheck:tsgo": "tsgo -p tsconfig.typecheck.json",
    "lint": "pnpm lint:ox && pnpm lint:eslint",
    "lint:fix": "pnpm lint:ox:fix && pnpm lint:eslint:fix",
    "lint:eslint": "eslint . --cache --cache-location node_modules/.cache/eslint/.eslintcache",
    "lint:eslint:fix": "eslint . --fix --cache --cache-location node_modules/.cache/eslint/.eslintcache",
    "lint:ox": "oxlint . --config .oxlintrc.json --no-error-on-unmatched-pattern",
    "lint:ox:fix": "oxlint . --config .oxlintrc.json --fix --fix-suggestions --no-error-on-unmatched-pattern",
    "encoding:check": "node ./scripts/check-encoding.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e:auth-state": "node ./scripts/e2e-auth-state.mjs",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "optimize:ai-style-images": "node ./scripts/optimize-ai-style-images.mjs",
    "backfill:list-avatar": "node ./scripts/backfill-space-avatar-compression.mjs",
    "backfill:space-avatar": "node ./scripts/backfill-space-avatar-compression.mjs",
    "prepare": "husky",
    "openapi": "openapi --input ./packages/tuanchat-openapi-client/tuanchat_OpenAPI.json --output ./packages/tuanchat-openapi-client/src --client fetch --name TuanChat",
    "electron:dev": "node ./scripts/electron-dev.mjs",
    "electron:dev:only": "electron .",
    "electron:prepare:resources": "node ./scripts/prepare-electron-extra-resources.mjs",
    "electron:build": "pnpm -s electron:prepare:resources && pnpm -s build && pnpm exec electron-builder build --config electron-builder.json",
    "electron:build:win:zip": "pnpm -s electron:prepare:resources && pnpm -s build && pnpm exec electron-builder build --config electron-builder.json --win zip",
    "electron:build:win:nsis": "pnpm -s electron:prepare:resources && pnpm -s build && pnpm exec electron-builder build --config electron-builder.json --win nsis",
    "electron:build:mac:zip": "pnpm -s electron:prepare:resources && pnpm -s build && pnpm exec electron-builder build --config electron-builder.json --mac zip",
    "electron:build:mac:dmg": "pnpm -s electron:prepare:resources && pnpm -s build && pnpm exec electron-builder build --config electron-builder.json --mac dmg"
  },
  "build": {
    "appId": "com.tuanchat.tuanchat",
    "productName": "团剧共创",
    "copyright": "Copyright © 2024 ${author}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "electron/icons/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "electron/icons/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "electron/icons"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@tanstack/react-router": "^1.169.2",
    "@tanstack/react-router-devtools": "1.166.13",
