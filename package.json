{
  "name": "tuan-chat-web",
  "type": "module",
  "version": "1.0.4",
  "private": true,
  "packageManager": "pnpm@9.6.0",
  "author": "Tuan Chat",
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "build:web": "pnpm web:build",
    "build:workspace": "pnpm build:web && pnpm mobile:web:build",
    "web:build": "pnpm --filter @tuanchat/web run build",
    "dev": "node ./scripts/dev.mjs",
    "web:dev": "pnpm --filter @tuanchat/web run dev",
    "dev:force": "node ./scripts/dev.mjs --force",
    "start": "node ./scripts/start.mjs",
    "web:start": "pnpm --filter @tuanchat/web run start",
    "mobile:android:dev": "powershell -ExecutionPolicy Bypass -File ./scripts/mobile-android-dev.ps1",
    "android:dev": "pnpm mobile:android:dev",
    "mobile:android:build": "powershell -ExecutionPolicy Bypass -File ./scripts/mobile-android-release.ps1",
    "android:build": "pnpm mobile:android:build",
    "mobile:android:emulator": "powershell -ExecutionPolicy Bypass -File ./scripts/mobile-start-android-emulator.ps1",
    "mobile:android:start": "powershell -ExecutionPolicy Bypass -File ./scripts/mobile-start-expo.ps1 -Android",
    "mobile:start": "pnpm --filter @tuanchat/mobile start",
    "mobile:android": "pnpm mobile:android:dev",
    "mobile:ios": "pnpm --filter @tuanchat/mobile ios",
    "mobile:web": "pnpm --filter @tuanchat/mobile web",
    "mobile:web:build": "pnpm --filter @tuanchat/mobile run build:web",
    "mobile:lint": "pnpm --filter @tuanchat/mobile lint",
    "mobile:typecheck": "pnpm --filter @tuanchat/mobile typecheck",
    "typecheck": "pnpm typecheck:web",
    "typecheck:all": "pnpm typecheck:web && pnpm typecheck:mobile",
    "typecheck:mobile": "pnpm mobile:typecheck",
    "typecheck:tsc": "pnpm --filter @tuanchat/web run typecheck:tsc",
    "typecheck:tsgo": "pnpm --filter @tuanchat/web run typecheck:tsgo",
    "typecheck:web": "pnpm --filter @tuanchat/web run typecheck",
    "typecheck:repo": "tsc -p tsconfig.typecheck.json",
    "lint": "pnpm lint:repo && pnpm lint:web && pnpm lint:desktop",
    "lint:all": "pnpm lint:repo && pnpm lint:web && pnpm lint:desktop && pnpm lint:mobile",
    "lint:all:full": "pnpm lint:repo && pnpm lint:web:full && pnpm lint:desktop && pnpm lint:mobile",
    "lint:fix": "pnpm lint:web:fix",
    "lint:desktop": "pnpm --filter @tuanchat/desktop run lint",
    "lint:mobile": "pnpm mobile:lint",
    "lint:repo": "oxlint . --config .oxlintrc.json --no-error-on-unmatched-pattern",
    "lint:ox": "pnpm lint:repo",
    "lint:ox:fix": "oxlint . --config .oxlintrc.json --fix --fix-suggestions --no-error-on-unmatched-pattern",
    "lint:web": "pnpm --filter @tuanchat/web run lint",
    "lint:web:full": "pnpm --filter @tuanchat/web run lint:full",
    "lint:web:fix": "pnpm --filter @tuanchat/web run lint:fix",
    "lint:web:full:fix": "pnpm --filter @tuanchat/web run lint:full:fix",
    "knip": "knip --no-progress",
    "encoding:check": "node ./scripts/check-encoding.mjs",
    "test": "pnpm --filter @tuanchat/web run test",
    "test:watch": "pnpm --filter @tuanchat/web run test:watch",
    "test:coverage": "pnpm --filter @tuanchat/web run test:coverage",
    "test:e2e:auth-state": "node ./scripts/e2e-auth-state.mjs",
    "e2e:browser-auth-snippet": "node ./scripts/e2e-browser-auth-snippet.mjs",
    "test:e2e": "pnpm --filter @tuanchat/web run test:e2e",
    "optimize:ai-style-images": "pnpm --filter @tuanchat/web run optimize:ai-style-images",
    "backfill:list-avatar": "node ./scripts/backfill-space-avatar-compression.mjs",
    "backfill:space-avatar": "node ./scripts/backfill-space-avatar-compression.mjs",
    "prepare": "husky",
    "openapi": "openapi --input ./packages/tuanchat-openapi-client/tuanchat_OpenAPI.json --output ./packages/tuanchat-openapi-client/src --client fetch --name TuanChat && node ./scripts/patch-openapi-api-result-guard.mjs",
    "desktop:dev": "pnpm --filter @tuanchat/desktop run dev",
    "desktop:dev:only": "pnpm --filter @tuanchat/desktop run dev:only",
    "desktop:check:resources": "pnpm --filter @tuanchat/desktop run check:resources",
    "desktop:prepare:resources": "pnpm --filter @tuanchat/desktop run prepare:resources",
    "desktop:build:app": "pnpm --filter @tuanchat/desktop run build:app",
    "desktop:build": "pnpm --filter @tuanchat/desktop run build",
    "desktop:build:win:zip": "pnpm --filter @tuanchat/desktop run build:win:zip",
    "desktop:build:win:nsis": "pnpm --filter @tuanchat/desktop run build:win:nsis",
    "desktop:build:mac:zip": "pnpm --filter @tuanchat/desktop run build:mac:zip",
    "desktop:build:mac:dmg": "pnpm --filter @tuanchat/desktop run build:mac:dmg",
    "release:electron": "node ./scripts/release-electron.mjs",
    "electron:dev": "pnpm desktop:dev",
    "electron:dev:only": "pnpm desktop:dev:only",
    "electron:prepare:resources": "pnpm desktop:prepare:resources",
    "electron:build": "pnpm desktop:build",
    "electron:build:win:zip": "pnpm desktop:build:win:zip",
    "electron:build:win:nsis": "pnpm desktop:build:win:nsis",
    "electron:build:mac:zip": "pnpm desktop:build:mac:zip",
    "electron:build:mac:dmg": "pnpm desktop:build:mac:dmg"
  },
  "devDependencies": {
    "@tuanchat/domain": "workspace:*",
    "@tuanchat/openapi-client": "workspace:*",
    "@tuanchat/typescript-config": "workspace:*",
    "@types/node": "^20",
    "eslint": "^9.39.2",
    "fast-glob": "^3.3.3",
    "husky": "^9.1.7",
    "knip": "5.82.1",
    "lint-staged": "^15.5.0",
    "openapi-typescript-codegen": "^0.29.0",
    "oxlint": "1.63.0",
    "sharp": "^0.33.5",
    "typescript": "5.8.2",
    "undici": "^6.21.0",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "@electron/node-gyp": "10.2.0-electron.1"
    }
  },
  "lint-staged": {
    "apps/web/**/*.{js,jsx,ts,tsx,mjs,cjs}": "oxlint --fix --fix-suggestions --config apps/web/.oxlintrc.json --no-error-on-unmatched-pattern",
    "apps/mobile/**/*.{js,jsx,ts,tsx,mjs,cjs}": "oxlint --fix --fix-suggestions --config apps/mobile/.oxlintrc.json --no-error-on-unmatched-pattern",
    "apps/desktop/**/*.{js,jsx,ts,tsx,mjs,cjs}": "oxlint --fix --fix-suggestions --config apps/desktop/.oxlintrc.json --no-error-on-unmatched-pattern",
    "{scripts,packages}/**/*.{js,jsx,ts,tsx,mjs,cjs}": "oxlint --fix --fix-suggestions --config .oxlintrc.json --no-error-on-unmatched-pattern",
    "*.{js,jsx,ts,tsx,mjs,cjs}": "oxlint --fix --fix-suggestions --config .oxlintrc.json --no-error-on-unmatched-pattern",
    "*.{ts,tsx,js,jsx,mjs,cjs,json,md,css,html,yml,yaml,ps1,sql}": "node ./scripts/check-encoding.mjs"
  }
}
