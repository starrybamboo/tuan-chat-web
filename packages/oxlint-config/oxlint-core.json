{
  "plugins": [
    "typescript",
    "unicorn",
    "react",
    "vitest",
    "node",
    "import"
  ],
  "overrides": [
    {
      "files": [
        "**/*.{js,jsx,ts,tsx}"
      ],
      "rules": {
        "typescript/no-redeclare": "off",
        "typescript/no-use-before-define": "off",
        "typescript/consistent-type-definitions": [
          "warn",
          "type"
        ],
        "react/no-array-index-key": "off",
        "unicorn/filename-case": [
          "error",
          {
            "cases": {
              "camelCase": true,
              "kebabCase": true,
              "pascalCase": true
            },
            "ignore": [
              "README.md"
            ]
          }
        ]
      }
    }
  ],
  "ignorePatterns": [
    ".codex-tmp/**",
    ".pnpm-patch-work/**",
    "build/**",
    "coverage/**",
    "dist/**",
    "node_modules/.cache/**",
    "node_modules/**",
    "release/**"
  ]
}
