{
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022", "ESNext"],
    "useDefineForClassFields": false,
    "rootDirs": [".", "./.react-router/types"],
    "module": "ES2022",
    "moduleResolution": "bundler",
    "paths": {
      "*": ["./*"],
      "react-router": ["./app/router/reactRouterCompat.tsx"],
      "@/*": ["./app/*"],
      "@tuanchat/domain": ["./packages/tuanchat-domain/src/index.ts"],
      "@tuanchat/domain/*": ["./packages/tuanchat-domain/src/*"],
      "@tuanchat/openapi-client": ["./packages/tuanchat-openapi-client/src/index.ts"],
      "@tuanchat/openapi-client/*": ["./packages/tuanchat-openapi-client/src/*"],
      "@tuanchat/query": ["./packages/tuanchat-query/src/index.ts"],
      "@tuanchat/query/*": ["./packages/tuanchat-query/src/*"]
    },
    "resolveJsonModule": true,
    "types": ["node", "vite/client", "vitest/globals"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true
  },
  "include": [
    "**/*",
    "**/.server/**/*",
    "**/.client/**/*",
    ".react-router/types/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build"
  ]
}
