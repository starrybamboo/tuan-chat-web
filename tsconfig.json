{
  "extends": "./tsconfig.packages.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "noEmit": true
  },
  "include": [
    "functions/**/*.ts",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "scripts/**/*.cts",
    "scripts/**/*.d.ts",
    "scripts/**/*.js",
    "scripts/**/*.mjs",
    "scripts/**/*.mts",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build"
  ]
}
