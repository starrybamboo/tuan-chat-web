{
  "extends": "@tuanchat/typescript-config/library.json",
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": "node_modules/.cache/tsc/typecheck.tsbuildinfo"
  },
  "include": [
    "packages/**/*.ts",
    "packages/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "doc-test2",
    "packages/**/__tests__/**",
    "packages/**/*.spec.ts",
    "packages/**/*.spec.tsx",
    "packages/**/*.test.ts",
    "packages/**/*.test.tsx"
  ]
}
