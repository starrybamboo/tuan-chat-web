{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": "node_modules/.cache/tsc/typecheck.tsbuildinfo",
    "paths": {
      "*": ["./*"],
      "react-router": ["./app/router/reactRouterCompat.tsx"],
      "@/*": ["./app/*"],
      "@tuanchat/domain": ["./packages/tuanchat-domain/src/index.ts"],
      "@tuanchat/domain/*": ["./packages/tuanchat-domain/src/*"],
      "@tuanchat/openapi-client": ["./packages/tuanchat-openapi-client/src/index.ts"],
      "@tuanchat/openapi-client/*": ["./packages/tuanchat-openapi-client/src/*"],
      "@tuanchat/query": ["./packages/tuanchat-query/src/index.ts"],
      "@tuanchat/query/*": ["./packages/tuanchat-query/src/*"],
      "@blocksuite/integration-test": ["./app/types/blocksuite-integration-test.d.ts"],
      "@blocksuite/integration-test/*": ["./app/types/blocksuite-integration-test.d.ts"]
    }
  },
  "include": [
    "app/**/*",
    ".react-router/types/**/*",
    "react-router.config.ts",
    "vite.config.ts",
    "electron/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "doc-test2"
  ]
}
